#!/bin/sh
# occ-vpnc-script — macOS vpnc-script replacement.
#
# Design goal: NEVER modify persistent DNS preferences. All DNS state
# lives in scutil's Dynamic Store, which is volatile — cleared by reboot
# and network state changes. When openconnect exits ungracefully, the
# worst case is a stale entry in State:/Network/Service/... but the
# user's Wi-Fi/Ethernet DHCP DNS is untouched, so internet keeps working.
#
# Compared to the default vpnc-script (which uses `networksetup
# -setdnsservers`), this avoids the "DNS broken until manual reset"
# failure mode after force-shutdown / battery loss / kernel panic.
#
# Called by openconnect via --script=<path-to-this>. Environment
# variables supplied by openconnect; `reason` tells us the phase.

set -e

# Service identifier = the tunnel interface name (e.g. utun4). This is the
# convention used by the stock vpnc-script and is what configd/mDNSResponder
# expect: the Service's IPv4 dict carries InterfaceName=$TUNDEV, which makes
# the resolver scope DNS queries for this Service through the tunnel. If we
# use a synthetic ID (e.g. occ-utun4), configd won't associate the DNS
# with the interface and DNS packets get routed via the physical default.
if [ -n "${TUNDEV:-}" ]; then
    SERVICE_ID="${TUNDEV}"
else
    SERVICE_ID="occ-$$"
fi

DNS_KEY="State:/Network/Service/${SERVICE_ID}/DNS"
IPV4_KEY="State:/Network/Service/${SERVICE_ID}/IPv4"
STATE_DIR="${HOME}/.occ"
STATE_FILE="${STATE_DIR}/last-script-state"

log() {
    # Log to a file we can inspect; tee would interfere with openconnect's output capture.
    mkdir -p "${STATE_DIR}" 2>/dev/null || true
    echo "[$(date -u +%FT%TZ)] [${reason:-?}] $*" >> "${STATE_DIR}/vpnc-script.log" 2>/dev/null || true
}

save_state() {
    # Remember values we need on disconnect that aren't re-supplied.
    mkdir -p "${STATE_DIR}" 2>/dev/null || true
    {
        echo "TUNDEV=${TUNDEV}"
        echo "VPNGATEWAY=${VPNGATEWAY}"
        echo "ORIG_DEFAULT_GW=${ORIG_DEFAULT_GW:-}"
        echo "ORIG_DEFAULT_IF=${ORIG_DEFAULT_IF:-}"
        echo "FULL_TUNNEL=${FULL_TUNNEL:-0}"
    } > "${STATE_FILE}"
}

load_state() {
    if [ -f "${STATE_FILE}" ]; then
        # shellcheck disable=SC1090
        . "${STATE_FILE}"
    fi
}

# ---------- connect / reconnect ----------

do_connect() {
    log "connecting TUNDEV=${TUNDEV} IP=${INTERNAL_IP4_ADDRESS} DNS='${INTERNAL_IP4_DNS}' SPLIT_DNS='${CISCO_SPLIT_DNS}' SPLIT_INC=${CISCO_SPLIT_INC:-0}"

    # 1. Remember the physical default gateway *before* we change routes,
    #    so we can add a pinned route to the VPN gateway (avoid loops).
    ORIG_DEFAULT_GW=$(route -n get default 2>/dev/null | awk '/gateway:/{print $2}' | head -1)
    ORIG_DEFAULT_IF=$(route -n get default 2>/dev/null | awk '/interface:/{print $2}' | head -1)

    # 2. Bring up the tunnel interface.
    MTU="${INTERNAL_IP4_MTU:-1412}"
    ifconfig "${TUNDEV}" inet "${INTERNAL_IP4_ADDRESS}" "${INTERNAL_IP4_ADDRESS}" mtu "${MTU}" up

    # 3. Routes. Pin VPN gateway via physical so tunnel packets don't try
    #    to go through themselves.
    if [ -n "${ORIG_DEFAULT_GW}" ] && [ -n "${VPNGATEWAY}" ]; then
        route add -host "${VPNGATEWAY}" "${ORIG_DEFAULT_GW}" 2>/dev/null || true
    fi

    FULL_TUNNEL=0
    if [ -n "${CISCO_SPLIT_INC:-}" ] && [ "${CISCO_SPLIT_INC}" -gt 0 ] 2>/dev/null; then
        # Split-include: add route per advertised range.
        i=0
        while [ "$i" -lt "${CISCO_SPLIT_INC}" ]; do
            eval "ADDR=\${CISCO_SPLIT_INC_${i}_ADDR:-}"
            eval "MASK=\${CISCO_SPLIT_INC_${i}_MASK:-}"
            if [ -n "${ADDR}" ] && [ -n "${MASK}" ]; then
                route add -net "${ADDR}" -netmask "${MASK}" -interface "${TUNDEV}" 2>/dev/null || true
            fi
            i=$((i + 1))
        done
    else
        # Full tunnel: default route via tunnel.
        FULL_TUNNEL=1
        route add default -interface "${TUNDEV}" 2>/dev/null || true
    fi

    # 3a. Force a host-route to each DNS server through the tunnel. The split-
    #     include list from the server may or may not cover the subnet of
    #     INTERNAL_IP4_DNS — it's group-policy-dependent and varies between
    #     sessions, so relying on it is unsafe. Without these host-routes the
    #     resolver tries to reach the VPN DNS via the physical default gateway
    #     (en0 / Wi-Fi), the packet leaves the corporate network entirely,
    #     and DNS lookups time out.
    #
    #     `route add` returns "route already in table" if a covering route
    #     already exists; we ignore the error either way.
    if [ -n "${INTERNAL_IP4_DNS:-}" ]; then
        for dns_ip in ${INTERNAL_IP4_DNS}; do
            route add -host "${dns_ip}" -interface "${TUNDEV}" 2>/dev/null || true
            log "added host route for DNS ${dns_ip} via ${TUNDEV}"
        done
    fi

    # 4. Register IPv4 + DNS for the tunnel Service in ONE scutil transaction.
    #    The stock openconnect vpnc-script wraps both sets in a single
    #    `open ... close` session, and we mirror that — empirically two
    #    separate scutil invocations caused configd to lose the connection
    #    between IPv4 and DNS dicts.
    #
    #    The crucial bit is SupplementalMatchDomains in the DNS dict: it
    #    tells mDNSResponder "queries for these domains MUST go to this
    #    resolver". Without it, macOS sends queries for *.lo.test-ai.net
    #    (a domain only the corporate DNS knows) to the Wi-Fi resolver,
    #    which returns NXDOMAIN, and the user sees "host not found".
    #    PrimaryRank=First or OverridePrimary alone is NOT enough — it
    #    only ranks the resolver, doesn't bind specific domains to it.
    #
    #    Match domains come from CISCO_DEF_DOMAIN (space-separated list of
    #    domains the corporate VPN considers "internal") and/or
    #    CISCO_SPLIT_DNS (comma-separated). We accept both.
    MATCH_DOMAINS=""
    if [ -n "${CISCO_SPLIT_DNS:-}" ]; then
        MATCH_DOMAINS=$(echo "${CISCO_SPLIT_DNS}" | tr ',' ' ')
    fi
    if [ -n "${CISCO_DEF_DOMAIN:-}" ]; then
        MATCH_DOMAINS="${MATCH_DOMAINS} ${CISCO_DEF_DOMAIN}"
    fi
    # Trim whitespace.
    MATCH_DOMAINS=$(echo "${MATCH_DOMAINS}" | xargs)

    SEARCH_LINE=""
    SUPPLEMENTAL_LINE=""
    PRIMARY_RANK_LINE=""
    if [ -n "${MATCH_DOMAINS}" ]; then
        SEARCH_LINE="d.add SearchDomains * ${MATCH_DOMAINS}"
        SUPPLEMENTAL_LINE="d.add SupplementalMatchDomains * ${MATCH_DOMAINS}"
    else
        # No match domains: fall back to making this resolver primary so
        # everything still goes through VPN DNS.
        PRIMARY_RANK_LINE="d.add PrimaryRank * First"
    fi

    scutil <<EOF
open
d.init
d.add Addresses * ${INTERNAL_IP4_ADDRESS}
d.add SubnetMasks * 255.255.255.255
d.add InterfaceName ${TUNDEV}
d.add OverridePrimary # 1
set ${IPV4_KEY}
d.init
d.add ServerAddresses * ${INTERNAL_IP4_DNS:-}
${SEARCH_LINE}
${SUPPLEMENTAL_LINE}
${PRIMARY_RANK_LINE}
set ${DNS_KEY}
close
quit
EOF

    log "DNS configured: match-domains='${MATCH_DOMAINS}' servers='${INTERNAL_IP4_DNS:-}'"

    # Kick mDNSResponder so it picks up the new config immediately.
    killall -HUP mDNSResponder 2>/dev/null || true

    save_state
    log "connected, DNS_KEY=${DNS_KEY}"
}

# ---------- disconnect ----------

do_disconnect() {
    load_state
    log "disconnecting"

    # Remove our DNS + IPv4 entries. Routes bound to the tunnel are auto-removed
    # when the tunnel goes down, but the pinned VPN gateway route must be
    # explicitly deleted.
    scutil <<EOF 2>/dev/null || true
remove ${DNS_KEY}
remove ${IPV4_KEY}
quit
EOF

    # Sweep any stale entries left by prior versions of this script that used
    # a synthetic "occ-*" service id. Best effort, ignore errors.
    STALE_KEYS=$(echo "list State:/Network/Service/occ-.*" | scutil 2>/dev/null | awk -F'= ' '/subKey/{print $2}')
    if [ -n "${STALE_KEYS}" ]; then
        {
            echo "${STALE_KEYS}" | while read -r k; do
                [ -n "$k" ] && echo "remove $k"
            done
            echo "quit"
        } | scutil 2>/dev/null || true
    fi

    if [ -n "${VPNGATEWAY:-}" ]; then
        route delete -host "${VPNGATEWAY}" 2>/dev/null || true
    fi

    if [ -n "${TUNDEV:-}" ]; then
        ifconfig "${TUNDEV}" down 2>/dev/null || true
    fi

    killall -HUP mDNSResponder 2>/dev/null || true
    rm -f "${STATE_FILE}" 2>/dev/null || true
    log "disconnected cleanly"
}

# ---------- main ----------

case "${reason:-}" in
    pre-init)
        : # nothing to do
        ;;
    connect)
        do_connect
        ;;
    disconnect)
        do_disconnect
        ;;
    reconnect)
        # openconnect re-established the TCP/DTLS session. Routes/interfaces
        # are in the same state, but let's reassert DNS in case Dynamic Store
        # was cleared by a network event.
        do_connect
        ;;
    attempt-reconnect)
        : # best-effort, nothing to do
        ;;
    *)
        log "unknown reason: ${reason:-}"
        ;;
esac

exit 0
